(function(){var __webpack_modules__={163:function(e,t,n){"use strict";n.d(t,{R:function(){return d}});var i=n(5384),o={nav:{home:"首页",application:"大赛报名",news:"新闻通知",competitionJudges:"大赛评委",pastReview:"往期回顾",relatedInformation:"相关资讯",organizingCommittee:"组委会",InterOrganizingCommittee:"国际组委会",login:"登录",register:"注册",unlogin:"退出登录",myRegistrations:"我的报名",personalCenter:"个人中心",title:"合成生物学创新赛",msgTitle:"消息盒",msgBtn:"查看全部",volunteer:"志愿者",myCertificate:"证书下载"},pastReview:{btn:"往届比赛视频",tabs:{tab1:"第二届合成生物学竞赛",tab2:"第一届合成生物学竞赛"}},home:{group_2:{title:"合成生物学创新赛简介",p1:"合成生物学创新赛由中国生物工程学会指导并委托合成生物学分会主办，深圳理工大学、中国科学院深圳先进技术研究院、深圳合成生物学创新研究院、深圳市合成生物学协会、国家生物制造产业创新中心联合承办。",p2:"创新赛聚焦合成生物学领域，汇聚全球领域内领军专家学者，面向对合成生物学有热情的在校大学生以及在读硕士研究生，为青年学生提供一个与顶尖学者面对面交流学习、展现自身创新力的创智、创造平台。",p3:"创新赛践行合成生物学“造物致知、造物致用”的理念鼓励当代学生从兴趣出发，探索合成生物学在不同领域的创新和应用，同时为合成生物学、生命科学、交叉学科培养后备生力军。"},group_3:{title:"合成生物学背景介绍",p1:"合成生物学是生命学科领域一门新兴的前沿交叉学科和典型的汇聚技术。",p2:"它通过融合工程科学理念与生命科学原理及基于多学科的使能技术，设计合成新的或改造天然的生命系统，揭示生命规律、构筑新一代工程生物体系；被喻为“认识生命的钥匙”（造物致知）、改变未来的颠覆性技术（造物致用）。",p3:"过去 20 年，系统生物学和基因组学获得大量知识积累，伴随 DNA 测序和合成技术、机器学习处理生物大数据、基因编辑工具、生物铸造工厂平台的出现和成熟，极大地推动了合成生物学的发展。拨钮开关与振荡器在活细胞里的遗传实现，病毒、细菌、酵母基因组的合成与功能展示，密码子拓展等是造物致知的典范。青蒿素、阿片类化合物等天然产物和生物基化工原料的大规模合成以及 mRNA 疫苗、合成食品等展现了未来工程生物学和生物技术的能量。合成生物学将为人类医疗健康、粮食安全、绿色生产、能源安全、环境安全、生物安全做出重要贡献。"},group_4:{title:"合成生物学竞赛介绍",p1:"合成生物学竞赛关注合成生物学创新及应用，致力于打通中国合成生物学领域的产、学、研、创、投通道，汇聚合成生物领域相关的学生和研究人员，联结高校、企业、资本、政府、园区、媒体、数据库等上下游全链条参与方，真正形成中国合成生物学的创新落地生态闭环，让合成生物学领域的创新想法有落地支撑的同时以产业需求驱动源头创新。"},group_5:{title:"大赛时间线 ",p1:"(北京时间)",pw:"大赛评委",sz:"大赛赛制",rc:"决赛日程",p2:"常规赛",p3:"细菌博弈赛",p4:"蛋白设计赛"},group_6:{zd:"指导单位",zb:"主办单位",cb:"承办单位",lh:"联合发起单位",zzs:"赞助商"}},account:{login:"用户登录",email:"邮箱",password:"密码",forgotPassword:"忘记密码",enterEmailAddress:"请输入邮箱地址",enterPassword:"请输入密码",noAddress:"还没有账号?",joinUsNow:"立即登录",getCode:"获取验证码",resend:"重新发送",passwordRule:"6-12个字符，需含大小写字母、数字，不允许有空格和中文",enterCode:"请输入验证码",confirmPassword:"再次输入密码",confirmPassword2:"请再次输入密码",register:"注册",alreadyHaveAnAccount:"已有账号,",Login:"立即登录",verificationCode:"验证码",signUp:"新用户注册",agree:"同意",terms:"用户服务协议",emailError:"邮箱格式错误",emailEmpty:"邮箱不能为空",passwordError:"格式错误,长度为6-12个字符,需含大小写字母、数字，不允许空格和中文",passwordEmpty:"密码不能为空",same:"两次输入密码不一致",codeError:"验证码格式错误",codeEmpty:"验证码不能为空",emailRegister:"邮箱注册",resetYourPassword:"重置密码",resetYourPassword2:"重置密码",backToLogin:"返回登录",newPassword:"新密码"},footer:{consultation:"关于竞赛的任何咨询：",complaint:"向监督委员会质疑或投诉：",competitionRules:"竞赛章程",privacy:"隐私政策"},application:{home:{title:"新颖的比赛形式",p1:"合成生物学创新赛由六个平行的板块组成:常规赛、大设施赛-细菌博弈、大设施赛-蛋白设计、大设施赛-合成细胞、负责任的生命科技创新，以及2026年新增赛道--企业命题挑战赛。",p2:"常规赛通过初赛的项目视频介绍和决赛的临场问答，考量参赛队伍的综合科学素质。",p3:"在细菌竞技赛道，参赛队伍对组委会统一提供的底盘细菌菌株进行自由改造，在决赛现场通过深圳市合成生物学重大科学设施实现两两竞技，规定时间内在竞技场占领地盘多者获胜。",p4:"在蛋白设计赛道，参赛队伍利用组委会提供的数据集对各自开发的AI模型进行训练并预测功能提高的蛋白突变子，大设施将构建、表达和表征这些蛋白突变子，预测出最高活性突变子的队伍获胜。",p5:"在合成细胞赛道，参赛队伍根据基因表达的分子生物学原理和文献报道的数据库，创造性的设计一段不超过140bp的任意DNA序列（包括启动子、5’UTR、RBS），用以在大肠杆菌裂解液中表达颜色蛋白，蛋白表达量高者获胜。",p6:"参赛队伍根据自身实际情况自由选择参加以上一项或多项。",p7:"在负责任的生命科技创新赛道，参赛队伍可选择合成生物学等生命科技领域研究前沿或生物经济产业创新的某个环节/领域，结合科技前沿与社会研究、实验或田野调查，分析其潜在伦理、安全风险，探讨促进该领域负责任创新、增进生物安全的科技或政策解决方案。评委将对队伍提交的方案进行综合评价，考察队伍分析与解决问题的科学性、创新性、可行性及跨学科合作创新能力。",p8:"在企业命题挑战赛道，参与主体不局限于在校学生。企业将发布与自身实际生产运营相关的合成生物学课题，面向所有感兴趣的团队开放参与。无论是项目方案，还是包含初步实验验证、更为成熟的成果形式，均在征集范围内。表现优异的团队将有机会获得企业投资，通过合作推动课题落地。",cont:"已报名"},routine:{tabs:{tab1:"比赛规则",tab2:"奖项设置"},rules:{group7:{title:"赛道分组",p1:"参赛队伍可根据项目方向进行赛道选择，目前赛道分为以下3个：",p2:"白色——工业",p3:"绿色——农业、环境",p4:"红色——健康、医疗"},group1:{title:"组队要求",p1:"1. 每支参赛队伍队长须为本科生；",p2:"2. 参赛队伍研究生占全队成员比例≤20%，且不超过3人，每支队伍不超过15人（不含指导老师）；",p3:"3. 原则上指导老师需为副高及以上职称（如有）。"},group2:{title:"报名材料及提交",subheadings1:"报名材料：",p1:"1. 项目展示：8分钟项目介绍视频（形式不限，鼓励多元化创作）+原创1篇科普小文章（中英均可，围绕参赛项目或其中某一重要内容）+1张项目海报（英文）；",p2:"2.队伍及项目相关信息：详见报名系统；",p3:"3. 其他：",btn1:"诚信承诺书",btn2:"生物伦理承诺书（如涉及）",btns:"下载模板",subheadings2:"提交方式：",p4:"于报名截止日期在报名系统内完成"},group3:{title:"比赛及交流形式",subheadings1:"【初赛】",p1:"初赛采用线上评审方式。",p2:"重点考察项目的原创性（创新性）、科学性、逻辑性、可行性，满分100分。",p3:"我们将依托中国科学院深圳先进院合成所的科普委员会对提交的科普小文章进行最佳科普文章奖的评审工作。",p4:"",subheadings2:"【决赛】",p5:"比赛环节：",p6:"决赛采用线下答辩方式。根据评委提前给出的针对性问题进行答辩演讲及现场问答，总时长15分钟，满分100分。最终成绩为初赛与决赛成绩按比例得出。",p7:"交流环节：",p8:"根据初赛分组，在每组完成比赛后，采取圆桌会议的形式。由该组评委与参赛队员在场上针对项目或该方向进行学术讨论。该环节不计入比赛成绩。"},group4:{title:"评审规则",subheadings1:"【初赛】",p1:"初赛成绩=85%视频+15%科普文章",subheadings2:"【决赛】",p2:"决赛成绩为现场答辩评委均分",p3:"最终成绩=60%初赛成绩+40%决赛成绩"},group5:{title:"评分指标",p3:"科学性",p4:"科学问题是否具有意义",p1:"创新性",p2:"选题、设计、实践的创新程度",p5:"逻辑性",p6:"结构完整性，逻辑清晰度",p7:"可行性",p8:"解决方案可行度，项目完成度"},group6:{p1:"创新赛大奖1名",p2:"工业赛道奖1名  ",p3:"农业、环境奖1名",p4:"健康、医疗奖1名",p5:"金奖若干",p6:"银奖若干",p7:"最受欢迎奖1名",p8:"最佳答辩奖1名",p9:"最佳科普文章奖1名"},group8:{title:"Polaris Toolkit基因设计工具",p1:"组委会推荐使用由大设施官方开发Polaris Toolkit一站式基因线路自动化组装工具：只需提交设计需求，智能平台即可自动完成序列优化、元件拼接与组装验证，大幅缩短“设计-构建-测试”周期，帮助选手快速实现合成生物学设计。",btn1:"访问Polaris Toolkit",btn2:"相关教程",file1:"Kit教程示例文件.zip"},btn:"我要报名"}},protein:{rules:{title:"比赛规则",p0:"<b>目标：</b>运用计算方法设计兼具高荧光亮度和优良热稳定性的GFP变体。",p1:"<b>基础：</b>以提供的野生型GFP序列为起点。",p2:"<b>任务：</b>参赛序列可从零设计，也可基于任意GFP家族参考序列优化。",p3:"<b>提交：</b>队伍需提交 6 条 经过设计和预测的突变序列。",p4:"<b>验证：</b>合成生物大设施将对所有通过验证（格式正确、不在排除列表内）的序列进行合成、表达（CFPS）、初始亮度测量Finitial、热处理、热后亮度测量Ffinal。每批包含WT对照。",t1:"<b>蛋白信息：</b>",p5:"竞赛所需的蛋白质信息（GFP序列、结构、相关数据等）已在报名系统中上传。参赛队伍在填写报名信息时，可在材料提交一栏中点击“下载资料”按钮，即可将官方资料一键收入囊中。",t2:"<b>得分规则 (针对单条序列)：</b>",p6:"相对亮度得分=Finitial/FinitialWT（评估蛋白在Cell-Free体系中的折叠效率与消光系数）。<br>热稳定性得分=Ffinal/Finitial（评估蛋白抵抗72°C高温变性的能力）。<br>极低亮度阈值：若某条提交序列的初始亮度不到同批次野生型sfGFP的30%（即Finitial<0.3×FinitialWT），说明该序列基础结构/功能遭到严重破坏，该序列直接淘汰出局，此条序列两项及总成绩均记为0分。<br>单条序列综合得分=相对亮度得分×热稳定性得分=",t3:"<b>奖项规则：</b>",p7:"参赛队伍提交的6条序列中得分最高的一条（Best Top-1）作为本队的最终打榜成绩进行排榜。前30%金奖、其余若干比例银奖。此外，设立由单项分决出的最佳亮度奖和最佳热稳定奖作为独立荣誉。",p8:"奖项1：最佳亮度奖 (Top 3): 按 队伍亮度总分 排名。 <br>奖项2：最佳热稳定性奖 (Top 3): 按 队伍热稳定性总分 排名 (若得分相同，亮度总分高者优先)。<br>奖项3：金/银奖 (综合排名约前 30%~50%)。",t4:"<b>提交材料：</b>",p9:"1、序列文件（.csv）：<br>（1）每队最多提交6条氨基酸序列；<br>（2）长度严格限制在220–250aa之间；<br>（3）字符规范：序列必须以蛋氨酸（M）开头，仅允许20种标准氨基酸大写字母，严禁包含终止密码子（如*）或标点符号；<br>（4）参赛序列可从零设计，也可基于任意 GFP 家族参考序列优化，不要求以 sfGFP 为母序列；<br>（5）本次由大设施统一合成DNA模板（已含启动子、RBS及终止子，且浓度标准化），因此参赛队伍只需提供氨基酸序列，本赛事使用开源DNAChisel算法执行反向翻译；<br>（6）请在提交前逐条与Exclusion_List.csv中的序列做完全一致性比对，确保提交的6条序列均未出现在Exclusion_List.csv文件中；<br>（7）表头规范：共三列，必须包含Team_Name（队伍名），Seq_ID（如1,2,3...），Sequence（氨基酸序列），可参考submission_template.csv。<br>2、设计思路文档（.pdf）：<br>（1）展示从零开始或组合现有模型（如ESM，ProteinMPNN等）生成序列的完整流程。阐述算法管线、如何平衡亮度和稳定性目标，以及最终筛选这6条序列的原因；<br>（2）LLM Agent：鼓励并欢迎使用各种大模型与代码Agent。若使用智能体设计，需在文档中展示Agent的逻辑树和关键执行日志，以确保过程可复现；<br>（3）该文档将作为评审团队的展示与思路参考。在客观得分相近的情况下，优先选择思路清晰、技术路径前沿且开源的队伍进行宣传和展示。<br>3、开源仓库链接：<br>（1）须提交公开的GitHub/GitLab/HuggingFace等代码托管仓库链接，确保可以复现；<br>（2）根目录需包含README.md，说明环境配置要求、模型依赖库以及推理代码运行方式。",btn:"我要报名",a1:"材料提交",a2:"6条预测的高性能序列",a3:"Excel或Csv文档，不超过10M",a4:"开源仓库链接",a5:"请将GitHub/GitLab/HuggingFace等代码托管仓库链接写在在txt文档内上传",a6:"设计简介",a7:"Word或PDF文档，不超过10M",downBtnName:"下载数据"},message:"注意：若有疑问请邮件联系 info{'@'}synbiochallenges.com"},bacteria:{title:"比赛规则",p0:"组队要求：参赛队伍人数不超过15人（不含指导老师）。</br> </br>",p1:"赛事组织方提供底盘细胞大肠杆菌MG1655菌株、红色质粒（mscarlet-I）、绿色质粒（GFP）。参赛队伍需将寄送的MG1655进行改造，并分别插入红绿两个质粒作为参赛菌株。每场竞技在两支队伍之间进行，由红对绿、绿对红两局组成；两局累计得分高者为获胜队伍。</br> </br>",p2:"在每一局比赛中，比拼双方菌种在同一软琼脂培养基板上占据生存空间的能力，比赛场地被划分为15×25共345个5毫米见方的小格子。双方细菌（随机分组）以相同密度分别接种在3H和21H格子的中心。评分规则为接种48小时后细菌所占据的面积大小，得分规则为：首先任何一方在方格内细菌总量超过阈值（以保证测量信噪比），才会被测量系统判定为有细菌占领。对于每一个格子，格子内任何一方细菌数量（用荧光总强度量化）占整个格子的总细菌数量超过70%，则该方得2分，在30%和70%之间，则判定双方各得1分。",p3:"",p4:"培养48小时\n处理数据并计分",p5:"",p6:"双方菌株趋化视频",p7:"（仅限中国内地队伍报名）",p8:"红菌获得胜利",btn:"我要报名",message:"注意：参赛队伍在本官网提交报名后，竞赛组委会将把参赛材料{'（'}MG1655菌株和红绿质粒{'）'}邮寄给参赛队伍。若有疑问请邮件联系：info{'@'}synbiochallenges.com"},synthetic_cell:{title:"比赛规则",t1:"<b>一、赛道背景</b>",p1:"利用蛋白质、核酸等有机大分子组装出具有代谢、生长、复制、分裂等特征的人工合成细胞是合成生物学领域的最新前沿，它的实现将不仅刷新我们对生命的认知，也将颠覆合成生物技术的应用场域。本赛道聚焦合成细胞研究的底层技术：遗传线路的设计及其在在无细胞系统中的表达。具体而言，启动子的序列、RBS序列、5’UTR的序列以及它们的组合都会影响目的基因的表达。比如，已知5’UTR的二级结构对mRNA的半衰期至关重要，但定量规律尚不明晰。如何设计调控序列对目的基因的表达最大化仍然是一个还未解决的基本问题。",t2:"<b>二、组队要求</b>",p2:"参赛队伍应由不超过15名队员组成（指导老师不计入人数）。",t3:"<b>三、比赛要求</b>",p3:'<b style="color:#597AFB">设计一段不超过140bp的DNA序列</b>（如下图蓝色部分），包括T7 RNA聚合酶识别的启动子区域和5’UTR（含RBS），直到起始密码子ATG结束（含ATG）。',p4:"参赛队伍提交以上序列后，创新赛组委会将合成以上序列，并利用深圳市合成生物重大科技基础设施，通过融合PCR将这段调控序列与上下游的序列组装成一段表达目的基因（GFP）的完整片段，定量后加入标准化的大肠杆菌裂解液无细胞反应体系中进行6小时反应，并通过对反应颜色的测量来对GFP表达水平进行定量。",t4:"<b>四、得分规则</b>",p5:"每队设计的调控序列对应的无细胞体系反应的GFP表达水平取值即为每队得分。",t5:"<b>五、奖项设置</b>",p6:"赛道最佳奖1名，得分前50%的队伍获得金奖、得分后50%的队伍获得银奖。",btn:"我要报名"},technological_innovation:{title:"比赛规则",t1:"<b>一、赛制介绍</b>",p1:"参赛队伍可以选择当前合成生物学等生命科技领域研究前沿或生物经济产业创新中的某个环节或某个领域，结合科技发展前沿和社会两个方面的研究、实验或田野调查，对其潜在的伦理、安全风险进行分析，探讨促进该领域负责任创新、增进生物安全的科技或政策解决方案。由评委对队伍提交的方案进行综合评价，考察队伍分析与解决问题的科学性、创新性、可行性，以及跨学科的合作创新能力。",t2:"<b>二、组队要求</b>",p2:"1、参赛队伍成员包括在读研究生或本科生；<br />2、参赛队伍成员一般不超过7人（不含指导教师）；<br />3、参赛队伍应当由跨学科背景的成员构成，同时包括理工背景和人文社科背景的队员；<br />4、参赛队伍可不包括指导教师，成员可来自不同学校。",t3:"<b>三、参赛材料形式</b>",p3:"参赛队伍针对所关注的所关注的问题，提交完整报告作为参赛评审材料，报告应该包括：",p4:"在对科技与社会两方面的实验、调查和分析基础上，分析潜在伦理、安全风险、社会影响和未来机遇",p5:"从科学技术或者社会政策等任一或多个角度，提出促进负责任创新和生物安全的解决方案",p6:"鼓励参赛队伍根据队伍特长自由探索，最终呈现的既可以是纯粹的政策建议，也可以是科技方案（比如内嵌的生物遏制措施），也可以是实践项目（比如生物安全的培训教育）。<br />提交报告应当是英文的。",t4:"<b>四、比赛及交流形式</b>",p7:"【初赛】初赛采用线上评审方式，由评委对队伍提交的报告进行打分评估。<br />【决赛】决赛采用线下答辩方式，队伍进行现场答辩，评委根据前期材料和现场汇报进行现场问答。最终成绩根据初赛和决赛成绩按50%和50%加权得出。<br />交流环节：将在决赛现场组织“生命科技负责任创新”青年论坛，参会专家和参赛队伍均可参与讨论，决赛优胜者将受邀进行论坛发言。",t5:"<b>五、奖项设置</b>",p8:"比赛将设置赛道最佳奖1名，金奖若干，银奖若干。",t6:"<b>六、参考题目</b>",p9:"队伍可根据自己关注生命科技和生物经济中的相关议题，自选角度自行开展组队研究，以下题目仅供参考：</br><b>1、如何实现生命科技前沿领域的负责任创新，避免潜在风险，比如</b></br>&nbsp;&nbsp;&nbsp;&nbsp;1)&nbsp;人工智能与合成生物学交叉融合发展<br />&nbsp;&nbsp;&nbsp;&nbsp;2)&nbsp;合成细胞<br />&nbsp;&nbsp;&nbsp;&nbsp;3)&nbsp;镜像生命<br />&nbsp;&nbsp;&nbsp;&nbsp;4)&nbsp;……</br><b>2、促进生命科技创新与生物经济发展中的规则或发展战略，比如</b></br>&nbsp;&nbsp;&nbsp;&nbsp;1)&nbsp;如何更好地对基于合成生物学设计的菌种或物种进行知识产权保护？<br />&nbsp;&nbsp;&nbsp;&nbsp;2)&nbsp;在合成生物技术的背景下，在生物多样性公约框架下关于生物遗传资源获取与惠宜分享不同国家存在许多争议，请结合当前的科技发展，从政策角度，设计一个可能的解决机制？<br />&nbsp;&nbsp;&nbsp;&nbsp;3)&nbsp;亚洲地区生物资源丰富，生物经济潜力巨大，基于目前的合作框架，更好地发挥亚洲地区各国优势，促进亚洲地区的生命科技创新和经济发展？<br />&nbsp;&nbsp;&nbsp;&nbsp;4)&nbsp;……<br /><b>3、促进全球及地区生物安全体系建设，比如</b></br>&nbsp;&nbsp;&nbsp;&nbsp;1)&nbsp;首届生物军控和生物安全东南亚地区研讨会于2024年10月在深圳成功举办。中国与东南亚国家联盟轮值主席国老挝担任共同主席，联合国裁军事务办公室提供支持。如何加强未来该地区的生物安全合作，应对全球生物安全威胁？<br />&nbsp;&nbsp;&nbsp;&nbsp;2)&nbsp;2025年是《禁止生物武器公约》五十周年，在新兴生物经济快速发展的背景下，未来如何加强《禁止生物武器公约》的建设？<br />&nbsp;&nbsp;&nbsp;&nbsp;3)&nbsp;设计一个提高青年对生物安保与生物安全重要性的培训项目。<br />&nbsp;&nbsp;&nbsp;&nbsp;4)&nbsp;……",btn:"我要报名"},industry_challenges:{rules:{title:"比赛规则",p0:"一、赛道介绍",p1:"企业命题挑战赛，是由合作企业发布真实技术需求，参赛团队针对性提供解决方案的竞赛单元。参与主体不局限于在校学生。企业将发布与自身实际生产运营相关的合成生物学课题，面向所有感兴趣的团队开放参与。无论是项目方案，还是包含初步实验验证、更为成熟的成果形式，均在征集范围内。表现优异的团队将有机会获得企业投资，通过合作推动课题落地。",p2:"二、组队要求",p3:"1、参赛主体：高校在读本科生、硕士生、博士生，或已毕业的创业团队（公司尚未融资），个人或团队均可参赛。<br/>2、团队规模：不超过15人，设队长1名。",p4:"三、参赛材料",p5:"1、项目方案书，方案内容应涵盖但不限于以下方面：<br/>&nbsp;\t•\t方案概述、拟解决的企业技术难题；<br/>&nbsp;\t•\t国内外现状、合成生物学设计思路与技术路线；<br/>&nbsp;\t•\t实验方法、可行性分析、预期成果/数据；<br/>&nbsp; • 团队介绍、知识产权说明、参考文献。",p6:"2、8分钟项目视频",p7:"3、项目海报（英文）",p8:"4、其他：",btn1:"诚信承诺书",btn2:"生物伦理承诺书（如涉及）",btns:"下载模板",p9:"四、比赛形式",p10:"<b>1、初赛（线上评审）</b><br/>提交全部材料，评委线上评审，重点考察项目的创新性、科学性、可行性，企业需求匹配度、完整性，满分100分。<br/><b>2、决赛（现场答辩）</b><br/>现场路演：根据项目本身进行演示介绍及现场问答，演示总时长15分钟，满分100分。<br/>与初赛评分规则一致，企业评委占比高，重点考察落地价值、成本、产业化前景，满分100分。",p11:"五、评分指标",p12:"• \t<b>创新性：</b>设计与实践的创新程度、技术突破的力度；<br/>\t• \t<b>科学性：</b>逻辑严谨、数据扎实、符合合成生物学原理；<br/>\t• \t<b>可行性：</b>实验可操作性、成本、周期、风险可控；<br/>\t• \t<b>企业需求匹配度：</b>精准解决命题痛点，具备产业化潜力；<br/>\t• \t<b>完整性：</b>材料齐全、表达清晰、答辩表现。",p13:"六、奖项奖励",p14:"\t• \t<b>奖项：</b>企业特别奖、金/银奖（若干）。<br/>\t• \t<b>奖励：</b>企业专家将以评委及项目星探身份莅临决赛现场，若团队项目获得认可，将有机会与行业龙头企业开展深度资源对接与合作，共同推进项目孵化及产品开发。",p15:"七、企业赛题",p16:"2026年合成生物学创新赛企业命题挑战赛道发布赛题如下： ",p17:"1、中国贵州茅台酒厂（集团）有限责任公司",p18:"<b>题目一：酿造微生物底盘细胞的工程化优化与性能提升</b>",p18_1:"背景：拜尔结合酵母、粟酒裂殖酵母、金山醋酸乳杆菌、植物乳杆菌、拟青霉、红曲霉等酿造微生物是发酵工业的核心生产载体，其性能直接决定发酵效率、产品品质及生产稳定性。传统酿造体系多依赖天然菌株或复杂微生物群落，存在成分不稳定、代谢不可控及批次差异大等问题，难以满足现代生物制造对标准化与可控性的要求。近年来，合成生物学的发展为底盘细胞的理性设计提供了新路径，通过基因编辑、代谢调控及适应性进化等手段，可实现微生物性能的定向优化。然而，当前研究多集中于底盘细胞的初步构建，针对发酵效率、环境耐受性及工业适应性的系统优化仍有不足。围绕酿造过程中的关键需求，",p18_2:"构建兼具高效转化能力、良好抗逆性及稳定发酵性能的工程化酿造微生物底盘细胞",p18_3:"，对于推动传统发酵产业向标准化、智能化方向发展具有重要意义。",p19:"<b>题目二：新型工业生物催化剂的挖掘、设计与工程化应用</b>",p19_1:"背景：工业酶是生物制造的核心“芯片”，广泛应用于食品、饲料、医药、材料、能源等领域。然而，自然界中绝大多数微生物尚未被培养，其编码的酶资源——被称为“酶暗物质”——仍未被开发。与此同时，人工智能与宏基因组学的深度融合正在重塑酶的发现范式，使得",p19_2:"从复杂微生物群落中高效挖掘耐热、耐酸、耐盐、耐有机溶剂等特种酶（如蛋白酶和淀粉酶）成为可能。开发具有自主知识产权的新型工业生物催化剂",p19_3:"，对于降低生物工艺成本、替代高能耗化学催化、实现绿色低碳制造具有重要意义。",p20:"<b>题目三：废弃生物质与二氧化碳的协同生物转化与高值化利用</b>",p20_1:"背景：废弃生物质（如农业秸秆、林业剩余物、食品加工残渣等）和温室气体CO₂是两种量大面广的可再生碳资源。传统上两者分别处理——生物质焚烧或填埋，CO₂直接排放，碳利用效率低。合成生物学提供了将它们在同一生物系统中协同转化的新路径：生物质水解液提供碳骨架和能量，CO₂作为补充碳源，有望显著提高目标产物的碳原子经济性。",p20_2:"开发“固-气双碳源”协同转化技术",p20_3:"，服务于生物燃料、生物可降解材料、微生物蛋白等高值产物的绿色制造，是双碳目标下循环经济的关键方向。",p21:"2、万华化学集团股份有限公司",p22:'<b>题目一：二氧化碳、氢气、合成氨为原料制备蛋白质</b><br/> 背景：在地球诞生之初（约40亿年前），大气中几乎没有氧气，充斥着CO₂、N₂、H₂、CH₄和H₂S。在这样的"原始汤"中，一类被称为化能自养古菌的生命悄然诞生。它们不依赖阳光，不消耗有机物，仅以地热驱动的水-岩反应产生的H₂为能量来源，以CO₂为唯一碳源，在黑暗的深海热液喷口附近，构建起了地球上最早的生命网络。复现35亿年前古菌以CO₂、H₂为源合成有机物的生命智慧，利用合成生物学构建人工碳固定体系，将二氧化碳、氢气、合成氨转化为单细胞蛋白。保障饲料蛋白自主供给，实现粮食安全与碳中和双赢。',p23:"<b>题目二：纤维素制糖成本突破</b><br/> 背景：木质纤维素生物质（秸秆、林业废弃物等）是地球上最丰富的可再生碳源，但预处理成本高、酶解效率低导致纤维素糖成本居高不下，制约了生物基材料的大规模产业化。从纤维素制糖全流程考虑，通过绿色预处理、高效酶制剂开发与工艺集成创新，突破纤维素糖生产成本瓶颈，使得纤维素糖生产成本≤3000元/吨（对比淀粉糖成本具备竞争力）。",p24:"<b>题目三：关键代谢物的生物通用传感器</b><br/> 背景：目前对于胞内的关键代谢产物的检测依赖于代谢组学等检测手段，检测时间较长，无法迅速得到结果。可设计通用的生物传感器对糖酵解、PPP途径、辅因子、TCA循环等关键代谢产物进行快速检测，判断菌种的代谢瓶颈。",p25:"<b>题目四：AI驱动的发酵动力学预测系统构建与发酵工艺优化</b><br/> 背景：生物发酵过程存在强非线性、时变性及多变量耦合特征，关键生化指标离线检测滞后性强，传统经验化工艺调控存在效率低、批次稳定性差、产物收率波动大等问题，制约发酵产业规模化升级。AI技术为发酵过程精准调控提供了新路径，但目前动力学预测模型存在数据融合性差、建模门槛高、建模周期长、不同工艺间适配性低。从AI模型构建-动力学特征挖掘-发酵流程工艺优化-的全链条考虑，通过融合物理信息神经网络（PINN）、长短期记忆网络（LSTM）等机器学习方法与发酵动力学方程，整合pH、溶氧、温度、代谢产物浓度、甚至代谢组、蛋白组等多源数据，构建高精度“机器学习—发酵动力学”混合预测模型，开发集实时监测、趋势预测、工艺优化的功能模块，实现发酵过程关键指标提前预测，工艺优化后关键指标提升≥20%，为工业发酵生产提供智能化指导方案。",p26:"<b>题目五：重金属检测生物通用传感器</b><br/> 背景：对于废水废液中的重金属检测，目前无法实现及时迅速和准备的检测，生物传感器能够实现微量、迅速的检测，可检测Hg²⁺、Pb²⁺、Cd²⁺、Zn²⁺、As³⁺、Au³⁺、Sb³⁺、UO₂²⁺、Ni²⁺、Cu²⁺等重金属。",p27:"<b>题目六：化工废液的微生物处理技术包括醇类、醛类、酸类、苯类，能够大幅度降低废水废液的处理成本</b><br/> 背景：针对化工行业醇类、醛类、酸类、苯类等典型有机废液，筛选高效降解功能菌株，构建复合微生物处理体系，实现废液中有机污染物的定向转化与资源回收；或以废水中高浓度有机物为碳源，通过代谢工程改造菌株，高效转化制备单细胞蛋白等高值产品，形成低成本、可工程化的绿色处理与资源化技术方案。",p28:"3、安徽华恒生物科技股份有限公司",p29:"<b>题目一：新型海洋细菌关键酶的挖掘与工程化应用</b><br/> 背景：工业酶是生物制造的核心驱动力，然而自然界中仍有海量“酶暗物质”亟待开发。海洋细菌因其独特的生存环境（如高盐、高压、寡营养等），进化出了具有特殊催化性能和极端环境耐受性的酶类资源。与此同时，随着合成生物学向更广泛的底盘细胞拓展，利用光合底盘或新型植物底盘进行绿色固碳制造已成为前沿方向。然而，海洋来源酶在异源底盘中的适配性及表达效率往往受限。通过宏基因组学与人工智能深度融合，从海洋细菌等新型底盘中高效挖掘具有工业应用潜力的关键酶（如特异性氧化还原酶、水解酶等），并通过理性设计与定向进化提升其催化性能与适配性，对于拓宽合成生物学原料谱、降低生物工艺成本及开发新型生物催化剂具有重要战略价值。",p30:"<b>题目二：高附加值中药成分的合成生物制造与途径重构</b><br/> 背景：中药是中华民族的瑰宝，其活性成分（如熊果苷、萜类、黄酮类等）在医药、保健及日化（如美白、抗氧化）领域具有极高的应用价值。传统中药成分主要依赖植物提取，面临植物资源受限、生长周期长、受气候影响大及提取纯化成本高昂等瓶颈，难以满足日益增长的市场需求。合成生物学为高附加值天然产物的绿色、可持续生产提供了颠覆性路径。通过解析植物中天然产物的复杂生物合成途径，将关键酶基因导入易于培养的微生物底盘（如大肠杆菌、酵母）中，构建高效的“微生物细胞工厂”，可实现中药成分的定制化、规模化发酵生产。围绕高附加值中药成分，突破复杂代谢途径的异源重构、代谢流平衡调控及关键酶活性提升等适配难题，开发高产、稳定的工程菌株，对于推动中药现代化和绿色生物制造具有重要产业价值。",p31:"<b>题目三：新型绿色农药产品的合成生物路线创制与应用</b><br/> 背景：农业的可持续发展对高效、低毒、环境友好的绿色农药提出了迫切需求。传统化学农药面临抗药性增加、环境残留及非靶标生物毒性等严峻挑战，而生物农药（如生物刺激素、多肽类、微生物代谢产物等）因其靶标特异性强、易降解等优势，成为新型农药发展的重要方向。合成生物学技术的引入，使得通过微生物发酵低成本、大规模生产复杂结构的绿色农药活性分子成为可能。围绕农业病虫害防治及作物营养的实际需求，设计并创制新型绿色农药的合成生物路线，突破底盘细胞耐受性差、合成途径不完整及产物分离纯化困难等技术壁垒，对于加速绿色农药的产业化进程、服务现代农业并保障生态安全具有重要现实意义。",btn:"我要报名"}},form:{upload:"上传",download:"下载模板",enter:"请输入",choose:"请选择",teamInfo:"队伍信息",addMaterial:"材料补充",addMaterialSub:"需补充材料",teamName:"队伍名称",conactEmail:"联系人 (队长) 电子邮件",enterConactEmail:"请输入联系人 (队长) 电子邮件",enterTeamName:"请输入队伍名称",schoolName:"学校名称",enterSchoolName:"请输入学校名称",competitionGrouping:"赛道",country:"所属国家",notice:"若无相应选项，请输入",mailingAddress:"邮寄地址",enterMailingAddress:"请输入邮寄地址，用于接受竞赛所需起始材料",itemInfo:"项目信息",itemName:"项目名称",enterItemName:"请输入项目名称",coupeArticle:"科普文章（ <span style='color:#c5c5ca'>针对整个项目或者项目中的一个概念写一篇给外行看的科普论文，1000字左右，将角逐最佳科普奖</span> ）。",emterCoupeArticle:"Word文档，不超过10M",itemLogo:"项目LOGO",enterItemLogo:"支持png/jpg/pdf格式<br>不超过15M",itemIntro:"项目简介及示意图",enterItemIntro:"请输入1000字以内的项目简介",itemVideo:"项目视频",enterItemVideo:"不超过300M",itemPoster:"项目海报",enterItemPoster:"57x84cm（宽x高）<br>支持png/jpg/pdf格式<br>不超过15M",otherTitle:"其他文件（PDF文档，每个文件均不超过1M）",o1:"校方参赛同意书",o2:"诚信承诺书",o3:"生物伦理承诺书（如涉及）",o4:"材料",title1:"常规赛报名",title2:"细菌博弈赛报名",title3:"蛋白设计赛报名",title4:"合成细胞",title5:"负责任的科技创新",title6:"企业命题挑战赛报名",save:"保存",saveMessage:"请将成员列表填写完整,或删除空列表",saveSuccess:"保存成功",saveRoutineMessage:"报名表保存成功！您可以修改报名表，直至$time报名截止。截止后系统将自动提交报名表。",saveProteinMessage:"报名表保存成功！您可以修改报名表，直至$time报名截止。截止后系统将自动提交报名表。",saveBacteriaMessage:"报名表保存成功！您可以修改报名表